# Jira REST API credentials — copy to .env (never commit .env)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token

# Agent model config — defaults used if absent
CLAUDE_MODEL=claude-opus-4-8
CODEX_MODEL=gpt-5.5

# Maximum duration for one headless actor before its process tree is stopped.
ACTOR_TIMEOUT_SECONDS=600

# Nombre maximum d'allers-retours d'une discussion multi-tours (SERZENIA-143).
# Chaque round = chaque participant parle une fois. Au-delà : synthèse forcée.
MAX_DIALOGUE_ROUNDS=3

# Identité projet — injectée dans tous les prompts agents
# PROJECT_NAME=SERZENIA
# APPROVER_NAME=Hajar
# FRAMEWORK_KEYS=SERZENIA-70,SERZENIA-89,SERZENIA-91

# Chemin absolu du dépôt source (passé en --dir aux agents claude.exe/codex.exe).
# Obligatoire si le launcher est lancé depuis un dossier autre que le repo (ex: dossier release).
# Si absent, le launcher tente de détecter automatiquement un dossier .git dans les répertoires parents.
# SERZENIA_REPO=C:\Users\najwa\OneDrive\Desktop\SERZENIA
