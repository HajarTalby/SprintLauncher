# Jira REST API credentials — copy to .env (never commit .env)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token

# Agent model config — defaults used if absent
CLAUDE_MODEL=claude-opus-4-8
# Modèle codex de raisonnement : analyse, pilotage, arbitrage, revue de code.
CODEX_MODEL=gpt-5.6-sol
# Modèle codex d'exécution : dev + QA (plus économique en quota).
CODEX_EXECUTION_MODEL=gpt-5.6-terra
# Effort de raisonnement codex appliqué à tous les acteurs codex (config.toml global = low).
CODEX_EFFORT=high

# Maximum duration for one headless actor before its process tree is stopped.
ACTOR_TIMEOUT_SECONDS=600

# Timeout dédié aux acteurs d'IMPLÉMENTATION (un vrai dev d'US prend 15-45 min).
IMPL_TIMEOUT_SECONDS=3600

# Nombre maximum d'allers-retours d'une discussion multi-tours (SERZENIA-143).
# Chaque round = chaque participant parle une fois. Au-delà : synthèse forcée.
MAX_DIALOGUE_ROUNDS=3

# Spécialisation des moteurs d'implémentation : les US front/UI vont au moteur
# front, les US backend au moteur back — pas de chevauchement de code sur un sprint.
# Les US non typées alternent entre les deux. La relève quota ignore la spécialisation.
# ENGINE_FRONT=GptImplementation
# ENGINE_BACK=ClaudeImplementation

# Revue croisée post-dev : chaque US implémentée est relue par l'autre moteur
# (observations uniquement, correctifs chez l'implémenteur). false pour couper.
# CROSS_REVIEW=true

# Fréquence des checkpoints d'intervention dans les discussions :
# round (défaut) = entre les rounds · turn = après chaque prise de parole.
# Plusieurs interventions enchaînables au même checkpoint dans les deux modes.
# INTERVENTION_MODE=round

# Implémentation parallèle : les moteurs front et back travaillent EN MÊME TEMPS,
# chacun sur sa file d'US (périmètres disjoints). Revues croisées en fin de phase.
# Quota consommé ~2x plus vite mais sprint ~2x plus court. false (défaut) = séquentiel.
# PARALLEL_IMPLEMENTATION=true

# Identité projet — injectée dans tous les prompts agents
# PROJECT_NAME=SERZENIA
# APPROVER_NAME=Hajar
# FRAMEWORK_KEYS=SERZENIA-70,SERZENIA-89,SERZENIA-91

# Chemin absolu du dépôt source (passé en --dir aux agents claude.exe/codex.exe).
# Obligatoire si le launcher est lancé depuis un dossier autre que le repo (ex: dossier release).
# Si absent, le launcher tente de détecter automatiquement un dossier .git dans les répertoires parents.
# SERZENIA_REPO=C:\Users\najwa\OneDrive\Desktop\SERZENIA

# QA outillée + remédiation (lot 8)
# QA_COMMAND=dotnet build --nologo && dotnet test --nologo
# MAX_REMEDIATION_CYCLES=2
# FFMPEG=C:\Tools\ffmpeg\bin\ffmpeg.exe   # vidéos de preuve DoD (gdigrab)

# Smoke E2E sur release reelle (injecte au verdict QA)
# RELEASE_COMMAND=dotnet publish src/SERZENIA.App -c Release -o artifacts/sprint6/release
# APP_EXE=artifacts/sprint6/release/SERZENIA.App.exe

# US de pilotage du sprint : détectée automatiquement par son titre Jira
# (« Pilotage Sprint <N> ») — la synthèse sprint-level (comité, verdict QA) y est
# publiée. À déclarer ici UNIQUEMENT si le titre ne suit pas la convention.
# PILOTAGE_US=SERZENIA-111

# Round 1 « à l'aveugle » dans les discussions : chaque membre produit SA propre
# analyse sans voir les autres, puis les tours suivants croisent
# (accords/désaccords/différentiel). true (défaut) — false pour revenir au séquentiel.
# BLIND_FIRST_ROUND=true

# CHAT LIVE : interventions lues par l'acteur PENDANT son tour (claude stream-json /
# codex app-server turn/steer). Smoke live validé le 2026-07-16 (claude + codex).
# Le canal codex (app-server) est marqué expérimental par codex : activer sur un run
# supervisé d'abord. Une intervention arrivée après la fin d'un tour n'est jamais
# perdue — elle est reversée en directive adressée à l'acteur.
# LIVE_CHAT=true

# Reprise automatique apres epuisement des deux quotas.
# Activee uniquement par l'option CLI --auto-resume-quota ; ce reglage ne change
# que le plafond d'attente.
# QUOTA_RESUME_MAX_HOURS=8

# Slack (SERZENIA-146) : un seul bot token (xoxb-...) ; l'app cree les canaux et poste
# via chat.postMessage. Scopes requis : chat:write, channels:manage, channels:read,
# channels:join. Ne jamais committer le vrai token.
SLACK_BOT_TOKEN=
# Canal par acteur (id ou nom). Optionnel : par defaut = nom de l'acteur (ccode/ag/codex/sl).
# Le script scripts/notify/provision-slack.ps1 cree les canaux et remplit ces ids.
SLACK_CHANNEL_CCODE=
SLACK_CHANNEL_AG=
SLACK_CHANNEL_CODEX=
SLACK_CHANNEL_SL=
