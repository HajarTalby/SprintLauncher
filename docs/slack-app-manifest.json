{
  "display_information": {
    "name": "SERZENIA Sprint Launcher",
    "description": "Notifications des acteurs du Sprint Launcher (ccode, ag, codex, sl) + interventions two-way (Socket Mode).",
    "background_color": "#1f2933"
  },
  "features": {
    "bot_user": {
      "display_name": "sprint-launcher",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:read",
        "channels:join",
        "channels:manage",
        "channels:history",
        "groups:history",
        "users:read",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
