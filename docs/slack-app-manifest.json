{
  "display_information": {
    "name": "SERZENIA Sprint Launcher",
    "description": "Notifications des acteurs du Sprint Launcher (ccode, ag, codex, sl).",
    "background_color": "#1f2933"
  },
  "features": {
    "bot_user": {
      "display_name": "sprint-launcher",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "incoming-webhook",
        "chat:write"
      ]
    }
  },
  "settings": {
    "incoming_webhooks": {
      "enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
